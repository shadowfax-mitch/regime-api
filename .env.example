# Environment variables for local development

# Path to regime data CSV
REGIME_DATA_PATH=/mnt/c/NinjaTrader/data/regime_data.csv

# Admin key for accessing /admin/stats endpoint
ADMIN_KEY=your_admin_key_here

# Database URL (PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/regime_api

# Redis URL (for rate limiting in production)
# REDIS_URL=redis://localhost:6379/0

# Stripe API key (for payments)
# STRIPE_SECRET_KEY=sk_test_...

# API domain
# API_DOMAIN=api.sentinel-algo.com

# ────────────────────────────────────────────────────────────────
# x402 MICROPAYMENT INTEGRATION (HTTP 402 Pay-Per-Query)
# ────────────────────────────────────────────────────────────────
# Enable USDC micropayments on Base network — agents pay per request

# Your USDC-receiving wallet on Base (eip155:8453)
X402_PAY_TO_ADDRESS=0xF1484AB5d105F238ebdaA88cf861D384EC7f3Eaa

# Base network identifier
X402_NETWORK=eip155:8453

# Coinbase x402 facilitator (handles payment verification)
X402_FACILITATOR_URL=https://x402.org/facilitator
